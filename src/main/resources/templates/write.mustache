<!DOCTYPE HTML>
<html>
<head>
    <title>방명록 작성</title>
    <meta charset="UTF-8">
</head>
<body>
    <h1>방명록 작성하기</h1>
    <hr>
    <form action="/guestbook/write" method="post">
        <div>
            <label for="author">작성자: </label>
            <input type="text" id="author" name="author" placeholder="작성자 이름을 입력하세요" required>
        </div>
        <br>
        <div>
            <label for="content">내용: </label><br>
            <textarea id="content" name="content" rows="5" cols="40" placeholder="내용을 입력하세요" required></textarea>
        </div>
        <br>
        <button type="submit">저장</button>
        <a href="/guestbook">취소</a>
    </form>
</body>
</html>
